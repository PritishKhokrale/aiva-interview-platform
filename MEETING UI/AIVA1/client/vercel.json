{
  "rewrites": [
    {
      "source": "/api/py/:path*",
      "destination": "https://__FLASK_BACKEND_URL__/api/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://__NODE_BACKEND_URL__/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://__NODE_BACKEND_URL__/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
